---
import { SITE, NAV } from '../consts';

const base = import.meta.env.BASE_URL; // e.g. "/lab-website-test/"
const here = Astro.url.pathname.replace(/\/+$/, '/'); // normalise trailing slash

const isActive = (href: string) => {
  const full = (base + href).replace(/\/+$/, '/');
  return here === full;
};
---

<header class="site-header">
  <div class="header-shell">
    <div class="brand">
      <h1 class="brand-title"><a href={base}>{SITE.title}</a></h1>
      <p class="brand-subtitle">{SITE.subtitle}</p>
    </div>

    <div class="header-actions">
      <nav id="site-menu" class="site-menu" aria-label="Primary">
        {
          NAV.map((item) =>
            'children' in item ? (
              <div class="menu-group">
                <span
                  class={`menu-trigger${
                    isActive(item.href) || item.children.some((c) => isActive(c.href)) ? ' active' : ''
                  }`}
                >
                  <a class="menu-link" href={base + item.href}>
                    {item.label}
                  </a>
                  <button
                    class="submenu-toggle"
                    type="button"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-controls={`submenu-${item.label.toLowerCase()}`}
                    aria-label={`${item.label} submenu`}
                  >
                    <span aria-hidden="true">▾</span>
                  </button>
                </span>
                <div class="submenu" id={`submenu-${item.label.toLowerCase()}`} role="menu">
                  {item.children.map((child) => (
                    <a class="submenu-link" role="menuitem" href={base + child.href}>
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a class={isActive(item.href) ? 'active' : undefined} href={base + item.href}>
                {item.label}
              </a>
            )
          )
        }
      </nav>

      <button class="icon-button theme-toggle" type="button" aria-label="Toggle dark mode">
        <span class="moon" aria-hidden="true">☾</span>
        <span class="sun" aria-hidden="true">☀</span>
      </button>

      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu">Menu</button>
    </div>
  </div>
</header>
