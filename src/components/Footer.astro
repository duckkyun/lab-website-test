---
import { SITE } from '../consts';

const year = new Date().getFullYear();
---

<footer>
  <div class="footer-shell">
    <div>
      <h2 class="footer-title">{SITE.title}</h2>
      <p class="footer-text">{SITE.subtitle}</p>
    </div>
    <div>
      <p class="footer-text">&copy; {year} Ryu Lab</p>
      <p class="footer-meta">
        <span class="footer-maintainer">Ryu Lab is maintained by <a href={SITE.repo}>duckkyun</a>.</span><br />
        <span class="footer-generated">This page was generated by <a href="https://docs.github.com/ko/pages">GitHub Pages</a>.</span>
      </p>
    </div>
  </div>
</footer>
