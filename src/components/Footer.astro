    <div>
      <h2 class="footer-title">{SITE.title}</h2>
      <p class="footer-text">{SITE.subtitle}</p>
    </div>
    <div>
      <p class="footer-text">&copy; {year} Ryu Lab</p>
      <p class="footer-meta">
        Ryu Lab is maintained by
        <a href={SITE.repo}>duckkyun</a>.<br />
        This page was generated by
        <a href="https://docs.github.com/ko/pages">GitHub Pages</a>.
      </p>
    </div>
  </div>
</footer>
