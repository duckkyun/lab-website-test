---
import { SITE } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import fontRegular from '../styles/fonts/pretendard/Pretendard-Regular.woff2?url';
import fontSemiBold from '../styles/fonts/pretendard/Pretendard-SemiBold.woff2?url';
import fontBold from '../styles/fonts/pretendard/Pretendard-Bold.woff2?url';

interface Props {
  title?: string;
  description?: string;
  fullscreen?: boolean;
}

const { title, description = SITE.description, fullscreen = false } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const base = import.meta.env.BASE_URL;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const homeUrl = new URL(base, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: SITE.title,
  alternateName: 'Ryu Laboratory',
  description: SITE.description,
  url: homeUrl,
  parentOrganization: {
    '@type': 'CollegeOrUniversity',
    name: 'Yonsei University College of Medicine',
    department: 'Department of Biomedical Sciences',
  },
  member: {
    '@type': 'Person',
    name: 'Ji-Hwan Ryu',
    jobTitle: 'Principal Investigator',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={base + 'favicon.ico'} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <!-- Preload fonts so Pretendard is ready at first paint; with
         font-display:optional this prevents any fallback-to-Pretendard reflow
         (which briefly wrapped the header subtitle to two lines). -->
    <link rel="preload" href={fontRegular} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={fontSemiBold} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={fontBold} as="font" type="font/woff2" crossorigin />

    <script is:inline>
      // Apply theme before first paint (no flash of the wrong theme).
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.dataset.theme = 'dark';
      }
    </script>
  </head>
  <body class={fullscreen ? 'home-view' : undefined}>
    <Header />

    <aside class="brand-rail">
      <div class="rail-brand">
        <span class="rail-logo">
          <img src={base + 'images/yonsei-symbol.png'} alt="Yonsei University" />
        </span>
        <span class="rail-word"><span>RYU</span><span>LAB</span></span>
      </div>
      <a class="rail-icon" href={base + 'contact/'} aria-label="Contact the lab">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 4h18a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Zm.9 2 8.1 5.4L20.1 6H3.9ZM3 6.8V19h18V6.8l-8.4 5.6a1 1 0 0 1-1.2 0L3 6.8Z"/></svg>
      </a>
    </aside>

    <main class="page-shell">
      <slot />
    </main>
    <Footer />

    <script>
      // Play the rail entrance on a fresh load — a refresh, or arriving from
      // outside — but keep it static when navigating between our own pages.
      const rail = document.querySelector('.brand-rail');
      if (rail) {
        const navType = (performance.getEntriesByType('navigation')[0] || {}).type;
        let internalRef = false;
        try {
          internalRef = !!document.referrer && new URL(document.referrer).origin === location.origin;
        } catch (e) {}
        const internalNav = (navType === 'navigate' || navType === 'back_forward') && internalRef;
        if (!internalNav) rail.classList.add('play');
      }

      // Delegated on document so a single binding covers the whole header.
      const menuEl = () => document.getElementById('site-menu');

      // Close any open nav dropdown(s) except an optional one to keep open.
      const closeSubmenus = (except: Element | null = null) => {
        document.querySelectorAll('.menu-group.is-submenu-open').forEach((g) => {
          if (g === except) return;
          g.classList.remove('is-submenu-open');
          g.querySelector('.submenu-toggle')?.setAttribute('aria-expanded', 'false');
        });
      };

      document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement;
        const menu = menuEl();

        // dark-mode toggle
        if (target.closest('.theme-toggle')) {
          const isDark = document.documentElement.dataset.theme === 'dark';
          if (isDark) {
            document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('theme', 'light');
          } else {
            document.documentElement.dataset.theme = 'dark';
            localStorage.setItem('theme', 'dark');
          }
          return;
        }

        // nav dropdown caret (e.g. People submenu)
        const caret = target.closest('.submenu-toggle');
        if (caret) {
          const group = caret.closest('.menu-group');
          const open = group?.classList.toggle('is-submenu-open');
          caret.setAttribute('aria-expanded', String(open));
          closeSubmenus(group);
          return;
        }

        // mobile menu open/close
        const toggle = target.closest('.menu-toggle');
        if (toggle && menu) {
          const open = menu.classList.toggle('is-open');
          toggle.setAttribute('aria-expanded', String(open));
          if (!open) closeSubmenus();
          return;
        }

        // tap outside an open menu → close it
        if (
          menu &&
          menu.classList.contains('is-open') &&
          !target.closest('#site-menu') &&
          !target.closest('.menu-toggle')
        ) {
          menu.classList.remove('is-open');
        }

        // tap outside an open dropdown → close it (links inside navigate away)
        if (!target.closest('.menu-group')) closeSubmenus();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          menuEl()?.classList.remove('is-open');
          closeSubmenus();
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 960) {
          menuEl()?.classList.remove('is-open');
          closeSubmenus();
        }
      });
    </script>
  </body>
</html>
