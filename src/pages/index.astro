---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base fullscreen>
  <section class="section hero-section">
    <div class="hero">
      <div class="hero-lead-col">
        <p class="eyebrow">Yonsei University College of Medicine</p>
        <h1 class="headline">A conversation between microbes and the body.</h1>
      </div>

      <div class="hero-barrier" aria-hidden="true">
        <span class="axis-label axis-top">Microbiota</span>
        <span class="axis-dot"></span>
        <span class="axis-label axis-bottom">Host</span>
      </div>

      <div class="hero-body-col">
        <p class="lead">
          Ryu Lab studies how gut and skin commensal microbiota shape host immune homeostasis and disease.
          We combine gnotobiotic models, dysbiosis-driven disease systems, and microbiome analysis to uncover
          the mechanisms linking tissues, microbes, and immunity.
        </p>

        <div class="button-row">
          <a class="button" href={base + 'research/'}>Research</a>
          <a class="button ghost" href={base + 'members/'}>Members</a>
        </div>
      </div>
    </div>
  </section>
</Base>
