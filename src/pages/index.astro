---
import Base from '../layouts/Base.astro';
import PublicationList from '../components/PublicationList.astro';

const base = import.meta.env.BASE_URL;
---

<Base>
  <section class="section hero-section">
    <div class="hero">
      <div class="hero-lead-col">
        <p class="eyebrow">Yonsei University College of Medicine</p>
        <h1 class="headline">A conversation between microbes and the body.</h1>
      </div>

      <div class="hero-barrier" aria-hidden="true">
        <span class="axis-label axis-top">Microbiota</span>
        <span class="axis-dot"></span>
        <span class="axis-label axis-bottom">Host</span>
      </div>

      <div class="hero-body-col">
        <p class="lead">
          Ryu Lab studies how gut and skin commensal microbiota shape host immune homeostasis and disease.
          We combine gnotobiotic models, dysbiosis-driven disease systems, and microbiome analysis to uncover
          the mechanisms linking tissues, microbes, and immunity.
        </p>

        <div class="button-row">
          <a class="button" href={base + 'research/'}>Explore research</a>
          <a class="button ghost" href={base + 'members/'}>Meet the lab</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Notice</p>
        <h2 class="section-title">What is new in the lab</h2>
      </div>
    </div>

    <div class="panel-grid">
      <article class="panel accent-panel">
        <h3>Award</h3>
        <p>Ji-Hwan Ryu received the 12th Sungjae Medical Award in the Basic Science Division.</p>
        <p><a href="https://bms.yuhs.ac/kor/information01.html?bmode=read&bid=news&id_no=563&l=1" target="_blank" rel="noreferrer">Read the announcement</a></p>
      </article>

      <article class="panel">
        <h3>Recent publication</h3>
        <p>Our recent review highlights how skin microbiota communicate with the host from early life to adulthood.</p>
        <p><a href="https://doi.org/10.1038/s12276-025-01427-y" target="_blank" rel="noreferrer">View publication</a></p>
      </article>

      <article class="panel">
        <h3>Openings</h3>
        <p>We welcome students and trainees interested in microbiome research, mucosal immunology, and tissue-resident cell biology.</p>
        <p><a href={base + 'contact/'}>Contact the lab</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Research</p>
        <h2 class="section-title">Research areas</h2>
      </div>
      <p class="section-note">Our work connects commensal microbiota, tissue-resident cells, and inflammatory disease across gut and skin systems.</p>
    </div>

    <div class="panel-grid">
      <article class="panel">
        <h3>Gut microbiome and host homeostasis</h3>
        <p>We study how commensal microbes support balanced immune function and healthy tissue physiology in the host.</p>
        <div class="chip-row">
          <span class="chip">gut microbiome</span>
          <span class="chip">homeostasis</span>
          <span class="chip">host physiology</span>
        </div>
      </article>

      <article class="panel">
        <h3>Skin microbiota and allergic inflammation</h3>
        <p>We investigate how early-life microbial exposure and skin dysbiosis shape inflammatory pathways and allergic disease.</p>
        <div class="chip-row">
          <span class="chip">skin microbiota</span>
          <span class="chip">allergy</span>
          <span class="chip">dysbiosis</span>
        </div>
      </article>

      <article class="panel">
        <h3>Tissue-resident cell biology</h3>
        <p>We aim to identify tissue-resident cell populations whose development and differentiation are regulated by commensal microbiota.</p>
        <div class="chip-row">
          <span class="chip">resident cells</span>
          <span class="chip">differentiation</span>
          <span class="chip">immunity</span>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Highlights</p>
        <h2 class="section-title">Publications and news</h2>
      </div>
      <p class="section-note">A small set of papers and milestones helps new visitors understand the lab's recent direction.</p>
    </div>

    <div class="panel-grid two">
      <article class="panel">
        <h3>Selected publications</h3>
        <PublicationList limit={3} />
        <p><a href={base + 'publications/'}>See all publications</a></p>
      </article>

      <article class="panel">
        <h3>Recent news</h3>
        <ul class="news-list">
          <li><b>2025-04-01.</b> <a href="https://doi.org/10.1038/s12276-025-01427-y" target="_blank" rel="noreferrer">Experimental &amp; Molecular Medicine review published on skin microbiota-host communication.</a></li>
          <li><b>2025-02-04.</b> <a href="https://bms.yuhs.ac/kor/information01.html?bmode=read&bid=news&id_no=563&l=1" target="_blank" rel="noreferrer">Ji-Hwan Ryu receives the 12th Sungjae Medical Award.</a></li>
          <li><b>2024-10-04.</b> <a href="https://doi.org/10.1038/s41467-024-53038-2" target="_blank" rel="noreferrer">Nature Communications paper published on lung interstitial macrophages and neutrophilic asthma.</a></li>
          <li><b>2024-02-14.</b> <a href="https://doi.org/10.1016/j.chom.2023.12.006" target="_blank" rel="noreferrer">Cell Host &amp; Microbe study published on early-life skin microbes and allergic inflammation.</a></li>
        </ul>
        <p><a href={base + 'news/'}>Browse all lab news</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="panel accent-panel">
      <p class="eyebrow">Join us</p>
      <h2 class="section-title">We welcome students and collaborators</h2>
      <p class="lead">
        We welcome integrated Ph.D. students, doctoral students, postdoctoral fellows, and collaborators interested in
        microbiome research, mucosal immunology, or tissue-resident cell biology. Please send a short CV and a brief
        note about your interests.
      </p>
      <div class="button-row">
        <a class="button" href={base + 'contact/'}>Contact the lab</a>
        <a class="button ghost" href={base + 'members/'}>View members</a>
      </div>
    </div>
  </section>
</Base>
