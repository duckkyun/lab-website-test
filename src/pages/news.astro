---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="News" description="Recent awards and publication highlights from Ryu Lab at Yonsei University College of Medicine.">
  <section class="section">
    <p class="eyebrow">News</p>
    <h2 class="page-title">Lab updates and announcements</h2>
    <p class="lead">Recent awards and publication highlights from Ryu Lab are collected here in reverse chronological order.</p>
  </section>

  <section class="section">
    <div class="timeline">
      <article class="timeline-item">
        <p class="timeline-date">2025-04-01</p>
        <h3>Experimental &amp; Molecular Medicine review published on skin microbiota-host communication</h3>
        <p>The review summarizes how commensal skin microbiota shape host physiology and immune responses from early life to adulthood.</p>
        <p><a href="https://doi.org/10.1038/s12276-025-01427-y" target="_blank" rel="noreferrer">Read the paper</a></p>
      </article>

      <article class="timeline-item">
        <p class="timeline-date">2025-02-04</p>
        <h3>Ji-Hwan Ryu receives the 12th Sungjae Medical Award</h3>
        <p>The announcement was published by Yonsei University Department of Biomedical Sciences.</p>
        <p><a href="https://bms.yuhs.ac/kor/information01.html?bmode=read&amp;bid=news&amp;id_no=563&amp;l=1" target="_blank" rel="noreferrer">Original announcement on the Yonsei BMS website</a></p>
      </article>

      <article class="timeline-item">
        <p class="timeline-date">2024-10-04</p>
        <h3>Nature Communications paper published on lung interstitial macrophages and neutrophilic asthma</h3>
        <p>The study describes a CD39+CD9+ lung interstitial macrophage population that suppresses IL-23/Th17-mediated neutrophilic asthma.</p>
        <p><a href="https://doi.org/10.1038/s41467-024-53038-2" target="_blank" rel="noreferrer">Read the paper</a></p>
      </article>

      <article class="timeline-item">
        <p class="timeline-date">2024-02-14</p>
        <h3>Cell Host &amp; Microbe study links early-life skin microbes to allergic inflammation</h3>
        <p>The paper identifies a skin microbe-dependent TSLP-ILC2 priming axis in early life that is later co-opted in allergic inflammation.</p>
        <p><a href="https://doi.org/10.1016/j.chom.2023.12.006" target="_blank" rel="noreferrer">Read the paper</a></p>
      </article>
    </div>
  </section>
</Base>
