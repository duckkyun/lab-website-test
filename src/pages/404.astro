---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const base = import.meta.env.BASE_URL;
---

<Base
  title="Page not found"
  description="The page you were looking for could not be found on the Ryu Lab website."
>
  <section class="section">
    <p class="eyebrow">Error 404</p>
    <h1 class="page-title">This page isn't here.</h1>
    <p class="lead">
      The page you were looking for could not be found — it may have moved, been renamed,
      or never existed. If a link on this site brought you here, please let me know so I can fix it.
    </p>

    <div class="button-row">
      <a class="button" href={SITE.issues} target="_blank" rel="noreferrer">Report on GitHub</a>
    </div>

    <p class="notfound-email">
      Prefer email? Reach the maintainer at <span class="email">{SITE.maintainerEmail}</span>
    </p>

    <p class="notfound-back"><a href={base}>← Back to home</a></p>
  </section>
</Base>

<style>
  .notfound-email {
    margin: 20px 0 0;
    color: var(--muted);
  }
  .notfound-email .email {
    color: var(--text);
    font-weight: 600;
    user-select: all; /* one click selects the whole address to copy */
  }
  .notfound-back {
    margin-top: 24px;
    color: var(--muted);
  }
</style>
