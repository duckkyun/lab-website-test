---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const base = import.meta.env.BASE_URL;

const links = [
  { label: 'Research', note: 'Our work across gut and skin systems', href: base + 'research/' },
  { label: 'Members', note: 'The people in the lab', href: base + 'members/' },
  { label: 'Publications', note: 'Recent papers from the lab', href: base + 'publications/' },
];
---

<Base
  title="Page not found"
  description="The page you were looking for could not be found on the Ryu Lab website."
>
  <section class="section">
    <p class="eyebrow">Error 404</p>
    <h1 class="page-title">This page isn't here.</h1>
    <p class="lead">
      The page you were looking for may have moved, been renamed, or never existed.
      The link below will take you back, and the maintainer would like to hear about any broken links.
    </p>
    <div class="button-row">
      <a class="button" href={base}>Back to home</a>
      <a class="button ghost" href={base + 'research/'}>Explore research</a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Quick links</p>
        <h2 class="section-title">Where to next</h2>
      </div>
      <p class="section-note">A few good places to pick up from.</p>
    </div>

    <div class="panel-grid">
      {
        links.map((l) => (
          <article class="panel">
            <h3>{l.label}</h3>
            <p>{l.note}</p>
            <p><a href={l.href}>Go to {l.label.toLowerCase()}</a></p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="panel accent-panel">
      <p class="eyebrow">Found a broken link?</p>
      <h2 class="section-title">Let the maintainer know</h2>
      <p class="lead">
        If a link on this site brought you here, please report it so it can be fixed —
        open an issue on GitHub or send a short email.
      </p>
      <div class="button-row">
        <a class="button" href={SITE.issues} target="_blank" rel="noreferrer">Report on GitHub</a>
        <a class="button ghost" href={`mailto:${SITE.maintainerEmail}?subject=Broken link on Ryu Lab site`}>
          Email the maintainer
        </a>
      </div>
    </div>
  </section>
</Base>
